{
  "name": "ticketshop-sy-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "backend"
  ],
  "scripts": {
    "start:app": "npm start -w apps/customer-app",
    "build:app": "npm run build -w apps/customer-app",
    "test:app": "npm test -w apps/customer-app",
    "deploy:app": "npm run deploy -w apps/customer-app",
    "start:backend": "npm start -w backend",
    "build:backend": "npm run build -w backend"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
