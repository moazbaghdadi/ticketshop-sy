# Copy to deploy/.env on the host and fill in real values.
# This file is safe to commit; deploy/.env must NOT be committed.

# --- Postgres ---
DB_USER=ticketshop
DB_PASSWORD=change-me-strong-random
DB_NAME=ticketshop

# --- Backend ---
# Generate with:  openssl rand -base64 48
JWT_SECRET=change-me-long-random-secret
JWT_EXPIRES_IN=7d

# Public URLs (used by backend for CORS + invitation links, and baked into the Angular bundles)
DASHBOARD_BASE_URL=https://admin.ts.ce-svcs.cc
CORS_ORIGINS=https://book.ts.ce-svcs.cc,https://admin.ts.ce-svcs.cc

# Used as build-arg for both Angular apps; must include the /api/v1 suffix
PUBLIC_API_URL=https://api.ts.ce-svcs.cc/api/v1
